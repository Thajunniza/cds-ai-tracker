{
  "name": "cds-ai-tracker",
  "version": "0.1.0",
  "description": "CAP plugin for AI usage tracking — per-user, per-agent, per-operation token and Capacity Unit cost attribution for SAP AI Core and SAP AI Foundation services.",
  "license": "Apache-2.0",
  "author": "Thajunniza",

  "main": "cds-plugin.js",

  "files": [
    "lib",
    "srv",
    "index.cds",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],

  "keywords": [
    "sap",
    "cap",
    "cds-plugin",
    "sap-btp",
    "ai",
    "generative-ai",
    "ai-governance",
    "sap-ai-core",
    "genai-hub"
  ],

  "peerDependencies": {
    "@sap/cds": ">=8.5"
  },

  "cds": {
    "requires": {
      "ai-tracker": {
        "model": "cds-ai-tracker"
      }
    }
  },

  "scripts": {
    "lint": "eslint .",
    "test": "jest",
    "format": "prettier . --write"
  },

  "devDependencies": {
    "@cap-js/cds-test": ">=1",
    "@cap-js/cds-types": "^0",
    "eslint": "^9",
    "jest": "^29",
    "prettier": "^3"
  },

  "engines": {
    "node": ">=18"
  }
}